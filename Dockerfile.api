FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY Application/dotNET/DataLayer/              ./DataLayer/
COPY Application/dotNET/WebLayer/               ./WebLayer/
COPY Application/dotNET/ASPdotNET_Core_Web_API/ ./ASPdotNET_Core_Web_API/

WORKDIR /src/ASPdotNET_Core_Web_API
RUN dotnet publish ASPdotNET_Core_Web_API.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app .
ENTRYPOINT ["dotnet", "ASPdotNET_Core_Web_API.dll"]
